{% assign announcement = shop.metafields.my_app.announcement %}

{% if announcement != blank %}

<style>
.announcement-banner{
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    background: red;
    color: white;
    text-align: center;
    padding: 12px;
    font-size: 16px;
    font-weight: 600;
    z-index: 9999;
}
body{
    padding-top: 45px;
}
</style>

<div class="announcement-banner">
    {{ announcement.value }}
</div>

{% endif %}

{% schema %}
{
  "name": "Announcement Banner",
  "target": "body",
  "settings": []
}
{% endschema %}